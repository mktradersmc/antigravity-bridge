{
  "name": "antigravity-bridge",
  "displayName": "Antigravity Bridge",
  "description": "Minimalistischer VS Code Server auf Port 6000 zur Steuerung von Antigravity",
  "version": "1.0.35",
  "publisher": "local",
  "repository": {
    "type": "git",
    "url": "https://github.com/local/local.git"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "active-bridge.start",
        "title": "Start Active-Bridge Server"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint"
  },
  "dependencies": {
    "express": "^4.18.2",
    "lucide-react": "^0.577.0",
    "react-router-dom": "^7.13.1",
    "ws": "^8.19.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "18.x",
    "@types/vscode": "^1.60.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.1.6"
  }
}
